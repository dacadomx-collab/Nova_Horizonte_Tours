# =============================================================================
# BLINDAJE MILITAR DEFINITIVO - NOVA HORIZONTE TOURS
# AUTOR: AXON_DCD (Ecosistema Controlado de Fricción Cero)
# =============================================================================

# 1. Establecer index.php como el punto de despegue oficial del subdominio
DirectoryIndex index.php

# 2. Desactivar el listado público de directorios (Cero espionaje de archivos)
Options -Indexes

# 3. Denegar acceso a cualquier archivo oculto que empiece con punto
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# 4. Bloqueo absoluto de archivos sensibles de configuración y registros
<FilesMatch "\.(env|ini|log|sql|git|md|yml|example)$">
    Require all denied
</FilesMatch>

# 5. Enrutamiento Inteligente y Protección de Carpetas
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Excepción explícita: portal de diagnóstico (token verificado internamente por PHP)
    RewriteRule ^core/tools/test_connections\.php$ - [L]

    # Bloquear acceso público directo a carpetas críticas de infraestructura
    RewriteRule ^(knowledge|core|CORE|logs|\.git|\.github)/ - [F,L]

    # REGLA DE FRICCIÓN CERO: Si el recurso solicitado no es un archivo real 
    # ni una carpeta existente, se procesa limpiamente a través de index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [L]
</IfModule>

# 6. Cabeceras de Seguridad Avanzada (Mitigación de XSS, CSRF y Clickjacking)
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# 7. Manejo de Errores Controlado por la Infraestructura
ErrorDocument 403 "Acceso denegado por Protocolo de Seguridad AXON_DCD."
ErrorDocument 404 "Recurso no encontrado en el ecosistema Nova Horizonte Tours."