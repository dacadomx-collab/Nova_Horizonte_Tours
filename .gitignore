# =============================================================================
# .gitignore — Nova Horizonte Tours
# DCD LABS / AXON_DCD — Protección estricta del repositorio
# Última actualización: 2026-06-04
# =============================================================================

# --- SECRETOS Y CREDENCIALES (NUNCA al repositorio) ---
.env
.env.local
.env.production
.env.staging
core/.env
*.env
info.txt
knowledge/info.txt
id_rsa
id_rsa.pub
*.pem
*.key
*.p12
*.pfx

# --- LOGS Y REGISTROS (directorio rastreado, contenido ignorado vía logs/.gitignore) ---
logs/*.log
*.log

# --- BASE DE DATOS Y BACKUPS ---
*.sql
*.db
*.sqlite
backups/

# --- ARCHIVOS TEMPORALES Y CACHÉ ---
*.tmp
*.temp
*.bak
*.orig
*.cache
*.swp
*.swo

# --- SISTEMA OPERATIVO ---
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
# Windows
Thumbs.db
Thumbs.db:encryptable
desktop.ini
$RECYCLE.BIN/
# Linux
*~

# --- IDEs Y EDITORES ---
.vscode/settings.json
.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- ARCHIVOS COMPRIMIDOS Y MULTIMEDIA PESADA ---
*.zip
*.rar
*.tar
*.tar.gz
*.7z
*.gz
*.mp4
*.mov
*.avi
*.mkv
*.wmv
*.flv
*.webm
*.m4v

# --- NODE (herramientas de build locales, si aplica) ---
node_modules/
.next/
out/
build/
.pnp
.pnp.js
*.tsbuildinfo
next-env.d.ts
.vercel
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
yarn.lock

# --- PRUEBAS / COVERAGE ---
/coverage/
/.nyc_output/

# --- ARCHIVOS PHPUNIT / COMPOSER (si aplica en el futuro) ---
vendor/
composer.lock
