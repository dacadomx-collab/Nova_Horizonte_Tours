; =============================================================================
; PROYECTO  : Nova Horizonte Tours
; ARCHIVO   : .env.example (Plantilla Segura — Versión Pública)
; USO       : Copiar este archivo como core/.env y rellenar con credenciales reales.
; ADVERTENCIA: NUNCA SUBIR EL ARCHIVO .env REAL A GITHUB.
; SINTAXIS  : Compatible con parse_ini_file() de PHP. Comentarios con ; únicamente.
;             Valores con caracteres especiales DEBEN ir entre comillas dobles "".
; =============================================================================

; --- Configuración de Entorno ---
APP_ENV="production"
APP_URL="https://nova.tourfindy.com"

; --- Configuración de Base de Datos (Producción: cPanel/MySQL) ---
DB_HOST="localhost"
DB_NAME="tourfindycom_nova_db"
DB_USER="tourfindycom_nova_db_user"
DB_PASS="[CONTRASEÑA_DE_BASE_DE_DATOS_AQUI]"

; --- API Keys y Secretos de Terceros ---
PAYPAL_CLIENT_ID="[TU_PAYPAL_CLIENT_ID_AQUI]"
PAYPAL_SECRET="[TU_PAYPAL_SECRET_AQUI]"
STRIPE_SECRET_KEY="[sk_test_AQUI]"

; --- Correo Corporativo (SMTP) ---
SMTP_HOST="nova.tourfindy.com"
SMTP_USER="hola@nova.tourfindy.com"
SMTP_PASS="[CONTRASEÑA_SMTP_AQUI]"
SMTP_PORT=465
SMTP_SECURE="ssl"

; --- Configuración CORS (Lista Blanca de Orígenes) ---
ALLOWED_ORIGINS="http://localhost,http://localhost:3000,https://nova.tourfindy.com"
